# Copy to .env and adjust as needed. All vars are prefixed with APP_.
# ── Application ──────────────────────────────────────────────
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
APP_LOG_JSON=false

APP_ENV=development
APP_NAME="Learning Analytics Dashboard"
APP_VERSION=1.0.0
DEBUG=false

# ── Integration Settings ──────────────────────────────────────
SKILL_PROFILER_BASE_URL=http://skill-profiler-service:8001
LEARNING_RECOMMENDATION_BASE_URL=http://learning-recommendation-service:8002
AI_TUTOR_BASE_URL=http://ai-tutor-service:8003
ASSESSMENT_BASE_URL=http://assessment-service:8004

INTEGRATION_TIMEOUT_SECONDS=30
INTEGRATION_MAX_RETRIES=3
INTEGRATION_RETRY_BACKOFF_SECONDS=1
