# Copy to .env and adjust as needed. All vars are prefixed with APP_.
# ── Application ──────────────────────────────────────────────
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
APP_LOG_JSON=false

APP_ENV=development
APP_NAME="Learning Analytics Dashboard"
APP_VERSION=1.0.0
DEBUG=false

# ── Integration Settings ──────────────────────────────────────
SKILL_PROFILER_BASE_URL=http://skill-profiler-service:8001
LEARNING_ASSISTANT_BASE_URL=http://localhost:8002
AI_TUTOR_BASE_URL=http://ai-tutor-service:8003
ASSESSMENT_BASE_URL=http://assessment-service:8004
ASSESSMENT_API_TOKEN=

INTEGRATION_TIMEOUT_SECONDS=30
INTEGRATION_MAX_RETRIES=3
INTEGRATION_RETRY_BACKOFF_SECONDS=1

# ── Database (PostgreSQL) ─────────────────────────────────────
# Either set DATABASE_URL directly (takes precedence), or the DB_* parts below.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/apex_analytics
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=apex_analytics
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Auto-create tables at startup (dev only; ignored in production).
# In production, leave this false and manage schema with Alembic migrations:
#   alembic upgrade head
DB_AUTO_CREATE_TABLES=false
